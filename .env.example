# ── GEO PULSE — конфигурация окружения ──
# Скопируйте в .env и заполните. Минимум для мирового контура: DB_PASSWORD +
# OPENROUTER_API_KEY (+ JINA_API_KEY для кластеризации сюжетов).

# === БАЗА ДАННЫХ (обязательно) ===
# Любой надёжный пароль. DATABASE_URL ДОЛЖЕН содержать тот же пароль.
DB_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://thermo:change-me-strong-password@db:5432/cis_thermometer

# === LLM (обязательно для анализа и брифингов) ===
# Ключ OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Необязательно: своя цепочка моделей (через запятую, первая — основная).
# По умолчанию (src/llm.py): deepseek/deepseek-v4-flash → xiaomi/mimo-v2.5 →
# google/gemini-2.0-flash-001 (DeepSeek V4 Flash ~10x дешевле Gemini 3 Flash).
LLM_MODELS=

# Необязательно: «тяжёлая» модель для пакетных JSON-задач (дедуп тредов,
# reanalyze, дайджесты) — единый переключатель для скриптов, которым нужен
# надёжный structured-output. Высокообъёмный анализатор статей живёт в
# LLM_MODELS (выше) и сюда не входит. По умолчанию — дешёвая китайская модель.
# Альтернативы: deepseek/deepseek-v3.2, xiaomi/mimo-v2.5,
# moonshotai/kimi-k2.6, deepseek/deepseek-v4-flash.
HEAVY_MODEL=xiaomi/mimo-v2.5-pro

# Необязательно: локальная Ollama как последний фолбэк (без ключей).
# Пример: http://172.17.0.1:11434
OLLAMA_URL=

# === Безопасность / прод-настройки (серверные, держать только в .env) ===
# Ключ для admin-эндпоинтов и методов записи. ПУСТО = admin/запись закрыты
# для всех (безопасно по умолчанию для публичного API). Задайте, если нужен
# доступ к /api/v1/admin/* — тогда шлите заголовок X-Admin-Key: <значение>.
ADMIN_API_KEY=

# CORS: список origin через запятую, или * для всех. Для прод-домена сузьте.
CORS_ORIGINS=*

# Пейсинг запросов к GDELT (сек). 5 по умолчанию; на «шумных» IP поднимите
# до 30–45, если ловите 429 Too Many Requests.
GDELT_PAUSE_SEC=5

# Авто-карантин источников: снять active после N подряд неудачных fetch.
# 0 (по умолчанию) = не отключать, только записывать причину (last_status/
# last_error/consecutive_failures видны в /api/v2/health/sources).
SOURCE_QUARANTINE_AFTER=0

# === EMBEDDINGS (нужно для threads/кластеризации сюжетов) ===
JINA_API_KEY=

# === Необязательные интеграции ===
OPENAI_API_KEY=
COMTRADE_API_KEY=

# === TELEGRAM (только если поднимаете vox-/tg-коллекторы) ===
# Оставьте пустым — telegram-сервисы не запустятся, мировой контур работает без них.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=geopulse_vox
VOX_MODEL=google/gemini-2.0-flash-001
