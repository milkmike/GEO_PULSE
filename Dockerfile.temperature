FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*
COPY requirements-base.txt requirements-temperature.txt ./
RUN pip install --no-cache-dir -r requirements-temperature.txt
COPY src/ src/
COPY scripts/calc_temperature.py scripts/build_threads.py scripts/generate_digests.py scripts/check_integrity.py scripts/collect_gdelt.py scripts/calc_ru_index.py scripts/detect_signals.py scripts/collect_fx.py scripts/
ENV PYTHONPATH=/app PYTHONUNBUFFERED=1 LANG=C.UTF-8
