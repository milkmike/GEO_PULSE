FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*
COPY requirements-base.txt ./
RUN pip install --no-cache-dir -r requirements-base.txt
COPY src/ src/
COPY scripts/load_un_votes.py scripts/auto_trade_loader.py scripts/generate_digests.py scripts/collect_sanctions.py scripts/collect_crea_imports.py scripts/
ENV PYTHONPATH=/app PYTHONUNBUFFERED=1 LANG=C.UTF-8
