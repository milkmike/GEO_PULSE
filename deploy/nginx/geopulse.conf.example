# GEO PULSE — reference reverse-proxy config (public dashboard + read-only API).
#
# WHY THIS MATTERS: the FastAPI app has NO built-in authentication. When the
# API is exposed to the internet, admin/cost/key endpoints and write methods
# must be blocked at the edge — otherwise anyone can read API spend, inspect
# key metadata, or mutate the source catalog. This config does that.
#
# Usage: copy to /etc/nginx/sites-available/geopulse, set server_name,
# symlink into sites-enabled, `nginx -t && systemctl reload nginx`, then
# `certbot --nginx -d YOUR_DOMAIN` for HTTPS. Does not touch other vhosts.

server {
    listen 80;
    server_name YOUR_DOMAIN;            # ← e.g. geopulse.example.com

    # ── Security: admin/cost/key endpoints are never public ──────────────
    # (most specific prefix wins, so this beats /api/ below)
    location /api/v1/admin/ { return 404; }

    # Optional: hide interactive API docs in production (they enumerate every
    # route incl. admin). Comment out if you want /docs public.
    location = /docs    { return 404; }
    location = /openapi.json { return 404; }

    # ── Public API: read-only (block POST/PUT/DELETE/PATCH) ──────────────
    # The dashboard only ever issues GET, so writes have no legitimate caller.
    location /api/ {
        limit_except GET HEAD OPTIONS { deny all; }
        proxy_pass http://127.0.0.1:8100;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Built-in mini-dashboard (HTML served by FastAPI; its XHRs go via /api/)
    location = /world { proxy_pass http://127.0.0.1:8100; proxy_set_header Host $host; }

    # ── Frontend (Next.js dashboard) ─────────────────────────────────────
    location / {
        proxy_pass http://127.0.0.1:3334;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
