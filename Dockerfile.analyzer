FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*
COPY requirements-base.txt requirements-analyzer.txt ./
RUN pip install --no-cache-dir -r requirements-analyzer.txt
COPY src/ src/
COPY scripts/analyze.py scripts/backfill_embeddings.py scripts/
ENV PYTHONPATH=/app PYTHONUNBUFFERED=1 LANG=C.UTF-8
